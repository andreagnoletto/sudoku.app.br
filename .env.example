# Variáveis usadas pelo docker-compose.yml
# No Coolify, defina-as em: Resource → Environment Variables
# (marque "Is Build Variable?" se precisar em build-time, aqui só runtime)

# Domínio público (sem protocolo). Ex: www.sudoku.app.br
SERVICE_FQDN_SUDOKU=www.sudoku.app.br

# Domínio "apex" para redirect 301 -> SERVICE_FQDN_SUDOKU. Ex: sudoku.app.br
APEX_DOMAIN=sudoku.app.br

# Ambiente Node
NODE_ENV=production
